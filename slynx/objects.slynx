component Counter {
    pub prop count: int
    Button {
        on_click: _ -> count
    }
}

component Pessoa{
    prop name: str;
    prop age: int;
    Text {
        text: name + "tem" + age + "anos"
    }
    Counter {
        count: age
    }
}

component Sla {}

func main(): Component {
    let mut pessoa = Pessoa(
        name:"123", age: 123
    );
    pessoa.name = "Jorge";
    pessoa.age = 255;
    pessoa = Pessoa(name: "jorge", age:pessoa.age + 3);
    Sla{}
}
